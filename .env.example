# .env.example — safe template, committed to git (no real secrets here)
# -----------------------------------------------------------------------
# Local development:   copy to .env.local and run `python main.py`
# Production server:   copy to /opt/har-api/.env on your server
# -----------------------------------------------------------------------

# Environment mode
#   local → loads .env.local, enables hot-reload, binds to 127.0.0.1
#   live  → uses system/container env, no hot-reload, binds to 0.0.0.0
ENV=local

# Server bind address
#   local:  127.0.0.1   (loopback only — safe for dev, not reachable outside)
#   live:   0.0.0.0     (all interfaces — required for Docker port mapping)
HOST=127.0.0.1

# Server port
PORT=8888

# Public URL used by API root metadata links (/ docs / redoc)
# Set this in Railway to your deployed domain.
PUBLIC_BASE_URL=https://museum-model1-production.up.railway.app

# Path to the pre-trained joblib model file
#   local:  har_position_model.joblib           (relative, from project root)
#   Docker: /app/har_position_model.joblib      (absolute, set in Dockerfile)
HAR_MODEL_PATH=har_position_model.joblib

# Number of sensor samples in one prediction window (must match training)
HAR_WINDOW_SIZE=128

# Samples between predictions in WebSocket streaming mode
HAR_STEP_SIZE=10
